  "jest": {
    "testEnvironment": "jest-environment-jsdom",
    "transform": {
      "^.+\\.jsx?$": "babel-jest"
    },
    "moduleFileExtensions": ["js","jsx"],
    "setupFilesAfterEnv": ["@testing-library/jest-dom"],
